# NBX Gateway — defina a URL para ativar chamadas (interações + login automático quando não há token manual).
VITE_NBX_GATEWAY_URL=https://seu-gateway.exemplo.com
# Opcional: se definido, pula POST /auth/login e usa Bearer fixo (ex.: pipelines).
VITE_NBX_ACCESS_TOKEN=
#
# customerId e channel nas interações são fixos na aplicação:
#   customerId = 00000000-0000-0000-0000-000000000002
#   channel = ECOMMERCE
#
# Login via POST /api/v1/auth/login (ex.: nbx / nbx conforme seu ambiente).
VITE_NBX_LOGIN_USERNAME=nbx
VITE_NBX_LOGIN_PASSWORD=nbx
# Opcional: customerId para GET /decision-access/customers/{customerId}/decision.
VITE_NBX_DECISION_CUSTOMER_ID=00000000-0000-0000-0000-000000000002
# Fallback opcional para endpoint antigo por decisionId.
VITE_NBX_DECISION_ID=
